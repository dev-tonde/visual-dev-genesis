# Supabase (required — the app throws at startup if either is missing)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# GitHub projects section (optional — username defaults to dev-tonde in src/lib/github.ts;
# a token raises the GitHub API rate limit)
VITE_GITHUB_USERNAME=your-github-username
VITE_GITHUB_TOKEN=

# Note: CORS_ORIGIN is NOT a client variable. It is a Supabase Edge Function secret
# (supabase/functions/send-contact-email) — set it via `supabase secrets set`.
